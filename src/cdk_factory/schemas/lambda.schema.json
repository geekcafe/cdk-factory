{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lambda Resource Config",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "docker": { "type": "object" },
    "ecr": { "type": "object" },
    "image_config": { "type": "object" },
    "handler": { "type": "string" },
    "runtime": { "type": "string" },
    "memory_size": { "type": "integer" },
    "timeout": { "type": "integer" },
    "environment_variables": { "type": "array" },
    "permissions": { "type": "array" },
    "layers": { "type": "array" },
    "api": { "type": "object" }
  },
  "additionalProperties": true
}
