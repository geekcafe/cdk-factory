{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "S3 Bucket Resource Config",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "use_existing": { "type": ["boolean", "string"] },
    "versioned": { "type": ["boolean", "string"] },
    "encryption": { "type": "string" },
    "lifecycle_rules": { "type": "array" },
    "removal_policy": { "type": "string" },
    "enforce_ssl": { "type": ["boolean", "string"] },
    "enable_event_bridge": { "type": ["boolean", "string"] },
    "auto_delete_objects": { "type": ["boolean", "string"] }
  },
  "additionalProperties": true
}
