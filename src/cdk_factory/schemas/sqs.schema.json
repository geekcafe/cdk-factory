{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SQS Resource Config",
  "type": "object",
  "properties": {
    "queues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "queue_name": { "type": "string" },
          "type": { "type": "string" },
          "visibility_timeout_seconds": { "type": "integer" },
          "max_receive_count": { "type": "integer" },
          "batch_size": { "type": "integer" },
          "add_dead_letter_queue": { "type": ["boolean", "string"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
